{
  "name": "@lemonade-social/cli",
  "version": "1.2.1",
  "type": "module",
  "description": "Lemonade CLI - manage events, communities, and tickets from the terminal",
  "homepage": "https://github.com/lemonadesocial/lemonade-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/lemonadesocial/lemonade-cli.git"
  },
  "keywords": [
    "lemonade",
    "events",
    "cli",
    "ai",
    "ticketing"
  ],
  "bin": {
    "lemonade": "./dist/index.js",
    "make-lemonade": "./dist/chat/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "yarn clean && tsc",
    "build:quick": "tsc",
    "verify-dist": "node scripts/verify-dist.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "generate": "yarn generate:mcp && yarn generate:graphql",
    "generate:mcp": "tsx src/codegen/generate-from-mcp.ts",
    "generate:graphql": "tsx src/codegen/generate-from-graphql.ts",
    "prepublishOnly": "npm run build && npm run verify-dist"
  },
  "files": [
    "dist/",
    "src/chat/skills/*.md",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^5.4.1",
    "cli-highlight": "^2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "figures": "^6",
    "ink": "^6.8.0",
    "open": "^10.1.0",
    "openai": "^6.33.0",
    "ora": "^8.2.0",
    "react": "^19.2.4",
    "string-width": "^7.2.0",
    "terminal-link": "^4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "nock": "^14.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
