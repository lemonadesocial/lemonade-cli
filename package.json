{
  "name": "@lemonade-social/cli",
  "version": "0.1.0",
  "description": "Lemonade CLI - manage events, communities, and tickets from the terminal",
  "homepage": "https://github.com/lemonadesocial/lemonade-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/lemonadesocial/lemonade-cli.git"
  },
  "keywords": [
    "lemonade",
    "events",
    "cli",
    "ai",
    "ticketing"
  ],
  "bin": {
    "lemonade": "./dist/index.js",
    "make-lemonade": "./dist/chat/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "generate": "yarn generate:mcp && yarn generate:graphql",
    "generate:mcp": "ts-node src/codegen/generate-from-mcp.ts",
    "generate:graphql": "ts-node src/codegen/generate-from-graphql.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "open": "^8.4.2",
    "openai": "^6.33.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "nock": "^14.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  },
  "license": "MIT"
}
